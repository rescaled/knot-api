# REQUIRED: static bearer token clients must send as `Authorization: Bearer <token>`.
KNOT_API_TOKEN=change-me

# Where zonefiles are written. Must match the `storage`/`file` of your member
# template exactly (default template expands to <storage>/<zone>.zone).
KNOT_API_ZONES_DIR=/var/lib/knot/zones

# knotd control socket.
KNOT_API_KNOT_SOCKET=/run/knot/knot.sock

# Template assigned to zones created through this API.
KNOT_API_ZONE_TEMPLATE=member

# Your catalog zone which is automatically protected from modification through the API.
KNOT_API_CATALOG_ZONE=

# Extra protected zones, comma-separated (not JSON).
KNOT_API_PROTECTED_ZONES=

# Control-socket timeouts in seconds.
KNOT_API_KNOT_TIMEOUT=10
KNOT_API_RELOAD_TIMEOUT=60

# conf-begin retry policy when a foreign transaction is open
# (exponential backoff: base, 2*base, 4*base, ...).
KNOT_API_TXN_RETRIES=5
KNOT_API_TXN_RETRY_BASE_DELAY=0.25

# Zonefile validation.
KNOT_API_KZONECHECK_BIN=kzonecheck
KNOT_API_KZONECHECK_TIMEOUT=10
KNOT_API_MAX_ZONEFILE_BYTES=2097152

# Explicit path to libknot shared library, if not in the default search path
# (default: libknot.so.16 via the loader).
KNOT_API_LIBKNOT_SO=

# Abort a leftover knotd configuration transaction at startup. Off by default:
# it would also kill a transaction an admin has open in knotc.
KNOT_API_ABORT_STALE_TXN_ON_STARTUP=false

KNOT_API_LOG_LEVEL=INFO
